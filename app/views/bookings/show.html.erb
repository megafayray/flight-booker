<h2>Flight Information</h2>

<p>
  <strong>Flight ID:</strong> <%= @booking.flight.id %><br>
  <strong>From:</strong> <%= @booking.flight.departure_airport.code %><br>
  <strong>To:</strong> <%= @booking.flight.arrival_airport.code %><br>
  <strong>Date:</strong> <%= @booking.flight.start_date.strftime("%B %d, %Y") %><br>
  <strong>Time:</strong> <%= @booking.flight.start_time.strftime("%I:%M %p") %><br>
  <strong>Duration:</strong> <%= @booking.flight.flight_duration %> minutes <br>
  <strong>Passengers:</strong> <%= @booking.passengers.count %>
</p>

<h2>Passenger Info</h2>
<ul>
  <% @booking.passengers.each_with_index do |passenger, i| %>
    <li>
      <h3>Passenger <%= i + 1 %>:</h3>
      Name: <%= passenger.name %> - Email: <%= passenger.email %>
    </li>
  <% end %>
</ul>