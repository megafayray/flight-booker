<h2>Flight Information</h2>

<p>
  <strong>Flight ID:</strong> <%= params[:flight_id] %><br>
  <strong>From:</strong> <%= @flight.departure_airport.code %><br>
  <strong>To:</strong> <%= @flight.arrival_airport.code %><br>
  <strong>Date:</strong> <%= @flight.start_date.strftime("%B %d, %Y") %><br>
  <strong>Time:</strong> <%= @flight.start_time.strftime("%I:%M %p") %><br>
  <strong>Duration:</strong> <%= @flight.flight_duration %> minutes <br>
  <strong>Passengers: </strong><%= @passengers %>
</p>

<h2>Enter Passenger Information:</h2>

<%= form_with model: @booking, local: true do |form| %>
  <%= form.hidden_field :flight_id, value: @flight.id %>

  <h2>Passengers</h2>
  <%= form.fields_for :passengers do |passenger_fields| %>
    <div class="passenger">
      <%= passenger_fields.label :name %>
      <%= passenger_fields.text_field :name %>

      <%= passenger_fields.label :email %>
      <%= passenger_fields.email_field :email %>
    </div>
    <hr>
  <% end %>

  <%= form.submit "Book Flight" %>
<% end %>